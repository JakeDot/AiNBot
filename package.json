{
  "name": "@jakebot/the-fortress-template",
  "version": "1.0.0",
  "description": "Security-hardened project template with comprehensive IT security framework",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:security": "jest tests/security",
    "test:penetrate": "jest tests/penetration",
    "test:crypto": "jest tests/security/crypto",
    "test:memory-safety": "jest tests/security/memory",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "fortress:init": "node scripts/init-fortress.js",
    "threat:scan": "node scripts/threat-scan.js",
    "audit:full": "node scripts/full-audit.js",
    "deps:audit": "npm audit",
    "compliance:report": "node scripts/compliance-report.js",
    "clean": "rm -rf dist coverage"
  },
  "keywords": [
    "security",
    "fortress",
    "hardening",
    "encryption",
    "compliance",
    "threat-detection",
    "incident-response"
  ],
  "author": "JakeDot",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "crypto": "^1.0.1",
    "events": "^3.3.0",
    "zlib": "^1.0.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
